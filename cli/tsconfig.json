{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "../dist-cli",
    "rootDir": "..",
    "types": ["node"],
    "paths": {
      "three": ["../node_modules/@types/three"]
    }
  },
  "include": ["./**/*.ts", "../src/**/*.ts"],
  "exclude": [
    "../src/main.tsx",
    "../src/App.tsx",
    "../src/components/**",
    "../src/hooks/**",
    "../src/**/*.test.ts",
    "../src/test-setup.ts",
    "../src/workers/render-worker.ts"
  ]
}
